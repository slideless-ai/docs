{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Slideless Documentation",
  "colors": {
    "primary": "#1E1432",
    "light": "#A78BFA",
    "dark": "#150E24"
  },
  "fonts": {
    "heading": {
      "family": "Satoshi",
      "weight": 700,
      "source": "https://cdn.fontshare.com/wf/BNPRT3ODDLFBWCXYJT3DHQD5HQ6KXIUF/TQZKMSQ7LSXFQXBNSJKXWQR3KMBNHYXW/SATOSHI-BOLD.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "Geist"
    }
  },
  "background": {
    "color": {
      "light": "#FDFCFB",
      "dark": "#0A0F1E"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://app.slideless.ai"
  },
  "appearance": {
    "default": "system"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Why Slideless",
            "pages": [
              "why-slideless/portable",
              "why-slideless/dynamic",
              "why-slideless/shareable"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/presentations",
              "concepts/share-tokens",
              "concepts/api-keys"
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "cli/overview",
              "cli/installation",
              "cli/configuration",
              "cli/auth",
              "cli/commands"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/with-claude",
              "guides/uploading-via-api",
              "guides/updating-in-place"
            ]
          },
          {
            "group": "Marketplace Skills",
            "pages": ["skills/overview"]
          },
          {
            "group": "Advanced: HTTP API",
            "pages": [
              "api-reference/overview",
              "api-reference/authentication",
              "api-reference/cli-auth",
              "api-reference/upload-presentation",
              "api-reference/update-presentation",
              "api-reference/list-presentations",
              "api-reference/get-presentation",
              "api-reference/get-shared-presentation",
              "api-reference/verify-api-key"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/slideless-ai",
          "icon": "github"
        },
        {
          "anchor": "App",
          "href": "https://app.slideless.ai",
          "icon": "rocket"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:team@slideless.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open the App",
      "href": "https://app.slideless.ai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "cursor", "mcp"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/slideless-ai"
    }
  }
}
