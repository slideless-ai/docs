{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Slideless Documentation",
  "colors": {
    "primary": "#29ff8d",
    "light": "#29ff8d",
    "dark": "#0a0a0a"
  },
  "fonts": {
    "heading": {
      "family": "JetBrains Mono",
      "weight": 800
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#f7f3e6",
      "dark": "#070710"
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://app.slideless.ai"
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["index", "quickstart"]
      },
      {
        "group": "Why Slideless",
        "pages": [
          "why-slideless/portable",
          "why-slideless/dynamic",
          "why-slideless/shareable"
        ]
      },
      {
        "group": "Concepts",
        "pages": [
          "concepts/presentations",
          "concepts/share-tokens",
          "concepts/api-keys"
        ]
      },
      {
        "group": "CLI",
        "pages": [
          "cli/overview",
          "cli/installation",
          "cli/configuration",
          "cli/auth",
          "cli/commands"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/with-claude",
          "guides/uploading-via-api",
          "guides/updating-in-place"
        ]
      },
      {
        "group": "Plugin Skills",
        "pages": ["skills/overview"]
      },
      {
        "group": "Advanced: HTTP API",
        "pages": [
          "api-reference/overview",
          "api-reference/authentication",
          "api-reference/cli-auth",
          "api-reference/upload-presentation",
          "api-reference/update-presentation",
          "api-reference/list-presentations",
          "api-reference/get-presentation",
          "api-reference/get-shared-presentation",
          "api-reference/verify-api-key"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/slideless-ai",
          "icon": "github"
        },
        {
          "anchor": "App",
          "href": "https://app.slideless.ai",
          "icon": "rocket"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:team@slideless.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open the App",
      "href": "https://app.slideless.ai"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "cursor", "mcp"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/slideless-ai"
    }
  }
}
